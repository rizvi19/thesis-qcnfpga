===== Generated constraint.sdc =====
# QFlow SKAG-W1 first physical-design constraint file

set clk_name clk
set clk_period 10.000

create_clock -name core_clock -period $clk_period [get_ports $clk_name]

set all_inputs_wo_clk [remove_from_collection [all_inputs] [get_ports clk]]
set_input_delay 1.000 -clock core_clock $all_inputs_wo_clk
set_output_delay 1.000 -clock core_clock [all_outputs]

# Treat reset as asynchronous control for this first implementation.
set_false_path -from [get_ports rst_n]

