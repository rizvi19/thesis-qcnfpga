hierarchy -check -top pareto_cmp_c1_scorefirst

proc
opt
memory
opt
fsm
opt
techmap
opt

abc

clean

stat

write_verilog asic/pareto_cmp_kernel/results/pareto_cmp_c1_scorefirst_synth_netlist.v
