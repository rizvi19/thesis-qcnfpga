# QFlow FDPE Kernel V1 LUT128 Yosys synthesis script
# Purpose: generate ASIC-style generic synthesis evidence for FDPE-V1.

read_verilog asic/fdpe_kernel/src/fdpe_kernel_v1_lut128.v

hierarchy -check -top fdpe_kernel_v1_lut128

proc
opt
memory
opt
fsm
opt
techmap
opt

abc

clean

stat

write_verilog asic/fdpe_kernel/results/fdpe_kernel_v1_lut128_synth_netlist.v
